# TrackWild Production Environment
# Copy to .env in deployments/ and fill in real values

# Database
POSTGRES_USER=trackwild
POSTGRES_PASSWORD=<generate-strong-password>
POSTGRES_DB=trackwild

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=<generate-32-byte-hex-string>
LOG_LEVEL=info
ENV=production
