:80 {

    encode gzip zstd

    # Proxy API requests to backend (preserve /v1/ prefix)
    handle /v1/* {
        reverse_proxy backend:8000
    }

    # Static frontend + SPA fallback (only for non-API routes)
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }
}
