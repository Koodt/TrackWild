:80 {

    encode gzip zstd

    # Proxy API requests to backend
    handle_path /v1/* {
        reverse_proxy backend:8000
    }

    # Static frontend
    root * /usr/share/caddy
    file_server

    # SPA fallback
    try_files {path} /index.html

    # No security headers locally (HSTS breaks localhost, CSP blocks MapLibre)
}
